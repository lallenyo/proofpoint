# ============================================================
# PROOFPOINT — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── App Configuration ─────────────────────────────────────────
# Base URL of your deployed app (used for OAuth redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Anthropic (server-side only — no NEXT_PUBLIC_ prefix) ────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Clerk Auth ────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Supabase ──────────────────────────────────────────────────
# Get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ-your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key-here

# ── Stripe (required for billing) ────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
# Create price IDs in Stripe Dashboard → Products
STRIPE_STARTER_PRICE_ID=price_starter_id_here
STRIPE_GROWTH_PRICE_ID=price_growth_id_here
STRIPE_SCALE_PRICE_ID=price_scale_id_here

# ── SendGrid (for email sending) ─────────────────────────────
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── HubSpot (for CRM sync) ───────────────────────────────────
# Get from https://developers.hubspot.com → Private Apps
HUBSPOT_ACCESS_TOKEN=pat-your-token-here

# ── Gmail/Outlook Email Integration (optional) ───────────────
# Google OAuth: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft OAuth: https://portal.azure.com → App Registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Salesforce Integration (optional) ────────────────────────
# Get from https://login.salesforce.com → Setup → App Manager → Connected Apps
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:3000/api/salesforce/auth

# ── Slack Integration (optional) ─────────────────────────────
# Get from https://api.slack.com/apps → OAuth & Permissions
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/slack/auth

# ── Sentry Error Tracking (optional) ─────────────────────────
# Get from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
